{
  "name": "scdl-core",
  "version": "5.0.1",
  "description": "A lightweight SoundCloud streaming module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "repository": "git@github.com:ducktrshessami/scdl-core.git",
  "author": "ducktrshessami",
  "license": "MIT",
  "scripts": {
    "prebuild": "tsc --noEmit",
    "build": "tsdown",
    "pretest": "yarn build",
    "test": "vitest"
  },
  "exports": {
    "types": "./dist/index.d.cts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.mjs"
  },
  "dependencies": {
    "m3u-parser-generator": "^5.0.2",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@scdl/fetch-client": "ducktrshessami/scdl-fetch-client#v1.0.3",
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
